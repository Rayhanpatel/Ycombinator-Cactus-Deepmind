# Copy to `.env` only if you need non-default settings.
# Most local setups can run with the defaults below.

# Optional API keys
CACTUS_API_KEY=
GEMINI_API_KEY=

# Optional Reddit credentials for authenticated online escalation.
# If blank, the app falls back to anonymous Reddit JSON search.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cactus-hvac-agent/0.1 (by u/anonymous)

# Model / generation
CACTUS_LLM_MODEL=google/gemma-4-E4B-it
CACTUS_FUNCTION_MODEL=google/functiongemma-270m-it
CACTUS_TRANSCRIPTION_MODEL=openai/whisper-small
MAX_TOKENS=512
TEMPERATURE=0.7

# Optional cloud fallback
ENABLE_CLOUD_FALLBACK=true
CLOUD_HANDOFF_THRESHOLD=0.5

# Shared audio
AUDIO_SAMPLE_RATE=16000
VAD_SENSITIVITY=0.5

# Rokid speech pipeline
ROKID_VAD_START_THRESHOLD=0.78
ROKID_VAD_END_THRESHOLD=0.58
ROKID_VAD_MIN_SILENCE_MS=280
ROKID_VAD_MIN_SPEECH_MS=320
ROKID_VAD_SPEECH_PAD_MS=96
ROKID_AUDIO_GATE_DB_OFFSET=12.0
ROKID_AUDIO_END_GATE_DB_OFFSET=7.0
ROKID_AUDIO_GATE_MIN_DBFS=-44.0
SPEECH_LANGUAGE=en
SPEECH_STT_MODEL=small.en
SPEECH_STT_DEVICE=cpu
SPEECH_STT_COMPUTE_TYPE=int8
SPEECH_TTS_LANG_CODE=a
SPEECH_TTS_VOICE=af_heart
ROKID_PUBLIC_PORT=8000
