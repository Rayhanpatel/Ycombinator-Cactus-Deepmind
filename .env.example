# ============================================
# Cactus x DeepMind Hackathon — Environment
# ============================================
# Copy this file to .env and fill in your keys
# cp .env.example .env

# Cactus API Key (from https://cactuscompute.com/dashboard/api-keys)
CACTUS_API_KEY=your_cactus_api_key_here

# Gemini API Key (from https://aistudio.google.com/api-keys)
# Required for cloud fallback on complex queries
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Model Configuration
# ============================================
# On-device LLM model (Gemma 4)
CACTUS_LLM_MODEL=google/gemma-4-E2B-it

# Function calling model
CACTUS_FUNCTION_MODEL=google/functiongemma-270m-it

# Transcription model
CACTUS_TRANSCRIPTION_MODEL=openai/whisper-small

# ============================================
# Agent Configuration
# ============================================
# Maximum tokens for on-device generation
MAX_TOKENS=512

# Temperature for generation (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7

# Enable cloud fallback (true/false)
ENABLE_CLOUD_FALLBACK=true

# Confidence threshold for cloud handoff (0.0-1.0)
CLOUD_HANDOFF_THRESHOLD=0.5

# ============================================
# Audio Configuration
# ============================================
# Sample rate for audio recording (Hz)
AUDIO_SAMPLE_RATE=16000

# VAD (Voice Activity Detection) sensitivity
VAD_SENSITIVITY=0.5
